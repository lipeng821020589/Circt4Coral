@@ -12,6 +12,17 @@ void state_t::add_csr(reg_t addr, const csr_t_p& csr)
 #define add_supervisor_csr(addr, csr) add_const_ext_csr('S', addr, csr)
 #define add_hypervisor_csr(addr, csr) add_ext_csr('H', addr, csr)
 
+// CoralNPU custom CSR: allows writes even for 0xFC0-0xFFF read-only range
+class coralnpu_csr_t : public basic_csr_t {
+ public:
+  coralnpu_csr_t(processor_t* const proc, const reg_t addr, const reg_t init):
+    basic_csr_t(proc, addr, init) {}
+  virtual void verify_permissions(insn_t insn, bool write) const noexcept override {
+    // Skip read-only check - CoralNPU accelerator CSRs are writable
+    // from M-mode
+  }
+};
+
